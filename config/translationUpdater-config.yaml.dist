inputFile: ../application/languages/en/views.php
outputFile: ../application/languages/en/zz_views.php

# Arrays for search and replace terms (must have the same number of elements)
search:
  - article
  - articles
  - an article
  - Article
  - Articles
  - An article

replace:
  - dataset/software
  - datasets/software
  - a dataset/software
  - Dataset/software
  - Datasets/software
  - A dataset/software

# The following options have moved to CLI flags:
#   case-sensitive  →  --case-sensitive
#   force           →  --force
#   silent          →  -q / --quiet
#   log             →  --log=<path>
#
# Usage example:
#   php scripts/console.php translations:update \
#     --config=config/translationUpdater-config.yaml \
#     --case-sensitive \
#     --force \
#     --log=tmp/translations.log