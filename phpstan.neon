parameters:
	level: 1
	# Required because global ignoreErrors patterns (e.g. constant.notFound) do not
	# match when running with a partial TARGET path (make phpstan TARGET=...).
	reportUnmatchedIgnoredErrors: false
	paths:
		- application
		- library
		- public
		- scripts
	excludePaths:
		- cache (?)
		- data (?)
		- log (?)
		- logs (?)
		- tmp (?)
		- vendor (?)
		- application/resources (?)
		- application/languages/en/Zend.php
		- application/languages/fr/Zend.php
	ignoreErrors:
		-
			identifier: constant.notFound
	bootstrapFiles:
		- phpstan-bootstrap.php