<?php
$this->jQuery()->addJavascriptFile(VENDOR_JQUERY_FILE_UPLOAD);
$this->jQuery()->addJavascriptFile('/js/library/es.fileupload.js');

$description = Episciences_Tools::buildAttachedFilesDescription();

/** @var Ccsd_Form $selfElement */
$selfElement = $this->element;
$attribsForm = $selfElement->getAttribs();
$submitElement = $selfElement->getElement('submitFinalVersionDeposit');
$pcId = 0;
$docId = 0;

foreach ($selfElement->getElements() as $element) {
    if ($element->helper === 'formHidden' && isset($element->pcId)) {
        $pcId = (int)$element->pcId;
        $docId = (int)$element->docId;
    }
}
?>
<form data-library="ccsd"
      role="form"
      action="<?= htmlspecialchars($selfElement->getAction(), ENT_QUOTES, 'UTF-8') ?>"
      method="<?= htmlspecialchars($selfElement->getMethod() ?: 'post', ENT_QUOTES, 'UTF-8') ?>"
      <?php foreach ($attribsForm as $name => $value) {
          if (in_array($name, ['action', 'method'], true)) {
              continue;
          }
          echo ' ' . htmlspecialchars($name, ENT_QUOTES, 'UTF-8') . '="' . htmlspecialchars($value, ENT_QUOTES, 'UTF-8') . '"';
      } ?>>
    <?php foreach ($selfElement->getElements() as $name => $element) : ?>
        <?php if ($name === 'submitFinalVersionDeposit') {
            continue;
        } ?>
        <?php if ($element->helper === 'formHidden') : ?>
            <?= $element; ?>
        <?php else : ?>
            <div id="<?= str_replace(['_', '-'], '', $name) ?>-element" class="form-group row">
                <?= $element; ?>
            </div>
        <?php endif; ?>
    <?php endforeach; ?>

    <div id="final-version-upload-<?= $pcId; ?>" class="form-group row">
        <label class="col-md-3 control-label">
            <?= $this->translate('Fichier final') ?> <span class="red">*</span>
        </label>
        <div class="col-md-9" style="padding-left: 10px">
            <div id="upload_widget_<?= $pcId; ?>" class="upload_widget" data-upload-container="final-version">
                <span id="help-block-<?= $pcId; ?>" class="help-block text-info"><?= $description; ?></span>
                <div id="upload_button_<?= $pcId; ?>" class="upload_button btn btn-default btn-xs select-files">
                    <span class="glyphicon glyphicon-folder-open"></span>
                    <?= $this->translate('Choisir le fichier final') . '...'; ?>
                </div>
                <input id="upload_input_<?= $pcId; ?>" class="upload_input" type="file" />
                <div class="uploads_container"></div>
            </div>
        </div>
    </div>

    <div class="form-actions text-center">
        <a class="btn btn-default" href="/paper/view?id=<?= $docId ?>"><?= $this->translate('Annuler') ?></a>
        <?= $submitElement ?>
    </div>
</form>

<script>
    paperCommentId = <?= $pcId ?>;
</script>
