                <?php endif; ?>
            </div>

            <!-- Ligne 2 : Volume (large) | DOI -->
            <div class="row">
                <?php if (isset($this->element->vid)) : ?>
                    <div class="col-sm-8">
                        <?= $this->element->vid ?>
