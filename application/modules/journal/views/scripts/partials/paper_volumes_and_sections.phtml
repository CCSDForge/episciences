$isAllowed = (
    (Episciences_Auth::isSecretary() || $this->article->getEditor(Episciences_Auth::getUid())) &&
    (Episciences_Auth::getUid() != $this->article->getUid() || APPLICATION_ENV === 'development')
);

if (!$isAllowed) {
    $disabled = 'disabled';
    $ariaDisabled = 'aria-disabled="true"';
}

