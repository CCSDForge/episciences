                                            <span class="fa-regular fa-copy"></span>
                                        </button>
                                        <span class="copy-feedback label label-success" style="display: none; margin-left: 8px; font-weight: normal; font-size: 0.75em;"><?php echo $this->translate('Copied!'); ?></span>
