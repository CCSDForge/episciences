<?php
// Generate CSRF token and store in session (per file to support multiple files on same page)
$session = new Zend_Session_Namespace('csrf_remove_file_comment');
if (!isset($session->tokens) || !is_array($session->tokens)) {
    $session->tokens = [];
}
$file = $this->comment['FILE'] ?? '';
$tokenKey = $this->comment['PCID'] . '_' . md5($file);
$csrfToken = bin2hex(random_bytes(32));
$session->tokens[$tokenKey] = $csrfToken;
$formId = 'del_pcid_' . $this->comment['PCID'];
?>
<form id="<?php echo $formId; ?>" method="post" action="/comments/removefilecomment">
    <input type="hidden" name="csrf_token" value="<?php echo htmlspecialchars($csrfToken, ENT_QUOTES, 'UTF-8'); ?>">
    <input type="hidden" name="csrf_token_key" value="<?php echo htmlspecialchars($tokenKey, ENT_QUOTES, 'UTF-8'); ?>">
    <input type="hidden" name="pcid" value="<?php echo (int)$this->comment['PCID']; ?>">
    <input type="hidden" name="docid" value="<?php echo (int)$this->comment['DOCID']; ?>">
    <input type="hidden" name="file" value="<?php echo htmlspecialchars($file, ENT_QUOTES, 'UTF-8'); ?>">
    <button type="button" class="btn btn-danger btn-xs pull-right"
            onclick="if(confirm('<?php echo addslashes($this->translate('Voulez-vous supprimer ce fichier?')); ?>')){document.getElementById('<?php echo $formId; ?>').submit();}">
        <span class="glyphicon glyphicon-trash" style="margin-right: 5px;"></span><?php echo $this->translate('Supprimer'); ?>
    </button>
</form>
