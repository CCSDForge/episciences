<?php
// Database profiler for the current page.
$mainProfiler = Zend_Db_Table_Abstract::getDefaultAdapter()->getProfiler();
$isMainProfilerEnabled = $mainProfiler->getEnabled();

// CAS profiler, when available.
$casProfiler = null;
$isCasProfilerEnabled = false;
$casConfig = [];

try {
    $casDb = Ccsd_Db_Adapter_Cas::getAdapter();
    $casProfiler = $casDb->getProfiler();
    $isCasProfilerEnabled = $casProfiler->getEnabled();
    $casConfig = $casDb->getConfig();
} catch (Exception $exception) {
    // CAS is not available in every execution context.
}

$formatElapsedTime = static function (float $elapsedTime): string {
    return number_format($elapsedTime, 4, '.', '');
};

$renderProfiler = function (string $title, Zend_Db_Profiler $profiler, array $config) use ($formatElapsedTime): void {
    ?>
    <section class="debug" style="border-top:1px solid #ddd;padding:0.5em;margin:0.5em">
        <h2 style="font-size:1.2em;margin:0 0 0.5em"><?php echo $this->escape($title); ?></h2>

        <dl class="dl-horizontal">
            <dt>Host</dt>
            <dd><strong><?php echo $this->escape($config['host'] ?? 'Unknown'); ?></strong></dd>

            <dt>Database</dt>
            <dd><strong><?php echo $this->escape($config['dbname'] ?? 'Unknown'); ?></strong></dd>

            <dt>Queries</dt>
            <dd><strong><?php echo $profiler->getTotalNumQueries(); ?></strong></dd>

            <dt>Total time</dt>
            <dd><strong><?php echo $formatElapsedTime($profiler->getTotalElapsedSecs()); ?> sec</strong></dd>
        </dl>

        <table class="table table-hover table-striped table-bordered table-condensed">
            <thead>
            <tr>
                <th style="width:auto"><i class="glyphicon glyphicon-tasks active"></i> Query</th>
                <th class="text-right" style="width:8em"><i class="glyphicon glyphicon-time active"></i> Time (sec)</th>
            </tr>
            </thead>
            <tbody>
            <?php foreach ($profiler->getQueryProfiles() as $query) { ?>
                <tr>
                    <td><small><?php echo $this->escape($query->getQuery()); ?></small></td>
                    <td class="text-right"><?php echo $formatElapsedTime($query->getElapsedSecs()); ?></td>
                </tr>
            <?php } ?>
            </tbody>
        </table>
    </section>
    <?php
};
?>
<?php if ($isMainProfilerEnabled) { ?>
    <?php
    $mainConfig = Zend_Db_Table_Abstract::getDefaultAdapter()->getConfig();
    $renderProfiler('Query Profiler - Main Database', $mainProfiler, $mainConfig);
    ?>

    <?php if ($isCasProfilerEnabled && $casProfiler) { ?>
        <?php $renderProfiler('Query Profiler - CAS Database', $casProfiler, $casConfig); ?>
    <?php } ?>

    <section class="debug" style="border-top:2px solid #000;padding:0.5em;margin:0.5em;background-color:#f0f0f0">
        <h2 style="font-size:1.2em;margin:0 0 0.5em">Query Totals (All Databases)</h2>

        <dl class="dl-horizontal">
            <dt>Main database</dt>
            <dd>
                <?php echo $mainProfiler->getTotalNumQueries(); ?> queries
                (<?php echo $formatElapsedTime($mainProfiler->getTotalElapsedSecs()); ?> sec)
            </dd>

            <dt>CAS database</dt>
            <dd>
                <?php if ($isCasProfilerEnabled && $casProfiler) { ?>
                    <?php echo $casProfiler->getTotalNumQueries(); ?> queries
                    (<?php echo $formatElapsedTime($casProfiler->getTotalElapsedSecs()); ?> sec)
                <?php } else { ?>
                    Not profiled or unavailable
                <?php } ?>
            </dd>

            <?php if ($isCasProfilerEnabled && $casProfiler) { ?>
                <dt>Grand total</dt>
                <dd>
                    <strong style="color:#0066cc;font-size:1.2em">
                        <?php echo $mainProfiler->getTotalNumQueries() + $casProfiler->getTotalNumQueries(); ?> queries
                        (<?php echo $formatElapsedTime($mainProfiler->getTotalElapsedSecs() + $casProfiler->getTotalElapsedSecs()); ?> sec)
                    </strong>
                </dd>
            <?php } ?>
        </dl>
    </section>
<?php } ?>
