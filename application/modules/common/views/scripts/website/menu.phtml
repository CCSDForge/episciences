<?php
$this->jQuery()
        ->addStylesheet('/css/website/menu.css')
        ->addJavascriptFile(VENDOR_SORTABLE_JS)
        ->addJavascriptFile('/js/website/menu-manager.js')
        ->addJavascriptFile('/js/website/menu.js');
?>
<meta name="csrf-token" content="<?php echo $this->escape($this->csrfToken); ?>">

<?php $this->layout()->pageDescription = $this->translate("Ajout/suppression de nouvelles pages dans le site") ?>

<?php //Ajout de nouvelles pages ?>
<div class="menu-toolbar">
    <label for="type" class="menu-toolbar__label"><?php echo $this->translate("Type de page") ?></label>
    <select name="type" id="type" class="menu-toolbar__select">
        <option value=""><?= $this->translate('Choisissez une page') ?></option>
        <?php foreach ($this->groupedPageTypes as $group => $types) : ?>
            <optgroup label="<?= $this->translate($group) ?>">
                <?php foreach ($types as $type) :

                    $label = sprintf('Episciences_Website_Navigation_Page_%s', ucfirst($type));
                    $disabled = '';

                    foreach ($this->pages as $page) {
                        if ($label === get_class($page) && !$page->isMultiple()) {
                            //La page est déjà ajoutée et non multiple
                            $disabled = ' disabled = "disabled"';
                            break;
                        }
                    }

                    ?>

                    <option value="<?= $this->escape($type) ?>" <?= $disabled ?>
                            type="<?= $this->escape($label) ?>"><?= $this->translate($this->escape($label)) ?><?php if (!empty($this->predefinedPageTypes[$type])): ?> 🛈 <?php endif; ?>
                    </option>

                <?php endforeach; ?>
            </optgroup>
        <?php endforeach; ?>
    </select>
    <button type="button" class="btn btn-primary menu-toolbar__btn"
            aria-label="<?php echo $this->escape($this->translate('Ajouter la page')) ?>"
            data-action="add-page">
        <i class="glyphicon glyphicon-plus" aria-hidden="true"></i>
        <?php echo $this->translate("Ajouter la page") ?>
    </button>
    <span class="menu-toolbar__sep"><?php echo $this->translate("ou") ?></span>
    <button type="button" class="btn btn-default menu-toolbar__btn"
            aria-label="<?php echo $this->escape($this->translate('Ajouter un dossier')) ?>"
            data-action="add-folder">
        <i class="glyphicon glyphicon-folder-open" aria-hidden="true"></i>
        <?php echo $this->translate("Ajouter un dossier") ?>
    </button>
</div>

<!-- aria-live region for screen reader announcements -->
<div aria-live="polite" aria-atomic="true" class="sr-only" id="menu-announcer"></div>

<?php //Liste des pages ?>
<form action="<?= $this->url(['controller' => 'website', 'action' => 'menu']) ?>" enctype="multipart/form-data"
      method="post" class="form-horizontal">
    <input type="hidden" name="csrf_token" value="<?php echo $this->escape($this->csrfToken); ?>">
    <ul class="menu-sortable" role="tree"
        aria-label="<?php echo $this->escape($this->translate('Structure du menu')) ?>">
        <?php foreach ($this->order as $key => $value) {
            $this->i = $key;
            if (!isset($this->pages[$key])) {
                continue;
            }
            $this->page = $this->pages[$key];
            ?>
            <li data-page-id="<?= $this->escape($this->page->getResource()) ?>"
                id="page_<?= (int)$this->i ?>"
                class="<?php echo $this->page->isFolder() ? '' : 'no-nest' ?>"
                role="treeitem"
                aria-level="1">
                <?php
                $isFolder1 = $this->page->isFolder();
                include __DIR__ . "/menu-page.phtml";
                if ($isFolder1) { ?>
                    <ul role="group">
                        <?php if (is_array($value)) {
                            foreach ($value as $k => $svalue) {
                                $this->i = $k;
                                if (!isset($this->pages[$k])) {
                                    continue;
                                }
                                $this->page = $this->pages[$k];
                                ?>
                                <li data-page-id="<?= $this->escape($this->page->getResource()) ?>"
                                    id="page_<?= (int)$this->i ?>"
                                    class="<?php echo $this->page->isFolder() ? '' : 'no-nest' ?>"
                                    role="treeitem"
                                    aria-level="2">
                                    <?php
                                    $isFolder2 = $this->page->isFolder();
                                    include __DIR__ . "/menu-page.phtml";
                                    if ($isFolder2) { ?>
                                        <ul role="group">
                                            <?php if (is_array($svalue)) {
                                                foreach ($svalue as $sk => $ssvalue) {
                                                    $this->i = $sk;
                                                    if (!isset($this->pages[$sk])) {
                                                        continue;
                                                    }
                                                    $this->page = $this->pages[$sk];
                                                    ?>
                                                    <li data-page-id="<?= $this->escape($this->page->getResource()) ?>"
                                                        id="page_<?= (int)$this->i ?>"
                                                        class="no-nest"
                                                        role="treeitem"
                                                        aria-level="3">
                                                        <?php include __DIR__ . "/menu-page.phtml"; ?>
                                                    </li>
                                                <?php }
                                            } ?>
                                        </ul>
                                    <?php } ?>
                                </li>
                            <?php }
                        } ?>
                    </ul>
                <?php } ?>
            </li>
        <?php } ?>
    </ul>

    <!-- Hidden template for new pages injected via addPage() -->
    <div id="clone" hidden>
        <li class="">
            <div class="menu-item">
                <button type="button" class="menu-drag-handle"
                        aria-label="<?php echo $this->escape($this->translate('Déplacer')) ?>">
                    <span aria-hidden="true">⠿</span>
                </button>
                <span class="menu-item-type-icon" aria-hidden="true">
                    <span class="glyphicon glyphicon-file menu-icon-page"></span>
                </span>
                <div class="menu-item-label">
                    <span class="menu-item-name"></span>
                    <div class="page-content"></div>
                </div>
                <div class="menu-item-actions">
                    <button type="button" class="menu-action-btn menu-action-btn--edit"
                            title="<?php echo $this->escape($this->translate('Modifier')) ?>"
                            data-action="toggle-edit">
                        <span class="glyphicon glyphicon-pencil" aria-hidden="true"></span>
                    </button>
                    <button type="button" class="menu-action-btn menu-action-btn--delete"
                            title="<?php echo $this->escape($this->translate('Supprimer')) ?>"
                            data-action="delete-page">
                        <span class="glyphicon glyphicon-trash" aria-hidden="true"></span>
                    </button>
                </div>
            </div>
        </li>
    </div>

    <div class="form-actions text-center">
        <a href="<?= $this->url(['controller' => 'website', 'action' => 'reset']) ?>">
            <button type="button" class="btn btn-default btn-sm"><?= $this->translate('Annuler') ?></button>
        </a>
        <button type="submit" class="btn btn-primary"><?= $this->translate('Enregistrer') ?></button>
    </div>

</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        window._menuManager = new MenuManager(document.querySelector('.menu-sortable'));
    });
