                $form->getElement($this->errors[$i])->setGroupErrors([$this->translate('Le champ Libellé est obligatoire dans toutes les langues')]);
            }

            if ($form->getElement('type')->getValue() == Episciences_Website_Header::LOGO_IMG) {
                $icon = '<span class="glyphicon glyphicon-picture active" aria-hidden="true"></span>';
                $text = $form->getElement('img_tmp')->getValue();
            } else {
                $icon = '<span class="glyphicon glyphicon-font active" aria-hidden="true"></span>';
                $textValues = $form->getElement('text')->getValue();
                $text = isset($textValues[Zend_Registry::get('lang')]) ? $textValues[Zend_Registry::get('lang')] : '';
            } ?>
            <li class="logo" id="logo-<?php echo $this->escape($i); ?>">
                <div class="menu-item">
                    <button type="button" class="menu-drag-handle" aria-label="<?php echo $this->escape($this->translate('Déplacer')) ?>"><span aria-hidden="true">⠿</span></button>
