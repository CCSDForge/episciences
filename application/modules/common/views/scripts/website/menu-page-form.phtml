<?php

$form = $this->page->getForm($this->i);
$form->removeDecorator('Form');

// Detach the labels element so we can render it ourselves as plain inputs
$labelsEl = $form->getElement('labels');
$form->removeElement('labels');

// Render one plain <input type="text"> per language with a language badge
if ($labelsEl !== null) {
    $pageName = 'pages_' . (int)$this->i;
    $labelsValues = (array)$labelsEl->getValue();
    $labelText = $this->escape($this->translate('Titre de la page'));
    $errors = $labelsEl->getMessages();
    $hasErrors = !empty($errors);
    ?>
    <fieldset class="form-group <?php echo $hasErrors ? 'has-error' : '' ?>">
        <legend class="control-label col-sm-3"><?php echo $labelText ?> <span class="text-danger">*</span></legend>
        <div class="col-sm-9">
            <?php foreach ($this->page->getLanguages() as $lang) { ?>
                <div class="input-group" style="margin-bottom:4px">
                    <span class="input-group-addon" aria-hidden="true">
                        <?php echo $this->escape(strtoupper($lang)) ?>
                    </span>
                    <input type="text"
                           name="<?php echo $this->escape($pageName) ?>[labels][<?php echo $this->escape($lang) ?>]"
                           id="<?php echo $this->escape($pageName) ?>-labels-<?php echo $this->escape($lang) ?>"
                           value="<?php echo $this->escape($labelsValues[$lang] ?? '') ?>"
                           class="form-control input-sm"
                           lang="<?php echo $this->escape($lang) ?>"
                           required="required"
                           aria-label="<?php echo $labelText ?> (<?php echo $this->escape(strtoupper($lang)) ?>)">
                </div>
            <?php } ?>
            <?php if ($hasErrors): ?>
                <ul class="help-block list-unstyled">
                    <?php foreach ($errors as $error): ?>
                        <li><strong><?php echo $this->escape($error) ?></strong></li>
                    <?php endforeach; ?>
                </ul>
            <?php endif; ?>
        </div>
    </fieldset>
    <?php
}

echo $form;

if (!$this->page->isMultiple()) {
    //Page simple
    ?>
    <script>
        (function() {
            const typeSelect = document.getElementById('type');
            if (typeSelect) {
                const option = typeSelect.querySelector('option[type="<?php echo $this->escape(get_class($this->page))?>"]');
                if (option) {
                    option.disabled = true;
                }
            }
        })();
    </script>
    <?php
}
if ($this->page->isFile()) {
    //Pour contourner le pb de Zend_File
    ?>
    <script>
        (function() {
            const formContainer = document.getElementById('form-<?php echo (int)$this->i ?>');
            if (formContainer) {
                formContainer.querySelectorAll('input[type="file"]').forEach(input => {
                    const currentName = input.getAttribute('name');
                    if (currentName && !currentName.startsWith('pages_')) {
                        input.setAttribute('name', 'pages_<?php echo (int)$this->i ?>[' + currentName + ']');
                    }
                });
            }
        })();
    </script>
    <?php
}
