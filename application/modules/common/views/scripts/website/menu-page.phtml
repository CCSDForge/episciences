<?php $isFolder = $this->page->isFolder(); ?>
<div class="menu-item">

    <button type="button" class="menu-drag-handle"
            title="<?php echo $this->escape($this->translate('Déplacer')) ?>"
            aria-label="<?php echo $this->escape($this->translate('Déplacer') . ' : ' . $this->page->getLabel(Zend_Registry::get('lang'))) ?>">
        <span class="glyphicon glyphicon-move" aria-hidden="true"></span>
    </button>

    <span class="menu-item-type-icon" aria-hidden="true">
        <?php if ($isFolder): ?>
            <span class="glyphicon glyphicon-folder-open menu-icon-folder"></span>
        <?php else: ?>
            <span class="glyphicon glyphicon-file menu-icon-page"></span>
        <?php endif; ?>
    </span>
    <div class="menu-item-label">
        <span class="menu-item-name"><?php echo $this->escape($this->page->getLabel(Zend_Registry::get('lang'))) ?><?php if ($this->page instanceof Episciences_Website_Navigation_Page_Predefined): ?> <span role="img" aria-label="<?php echo $this->escape($this->translate('Page prédéfinie')) ?>">🛈</span><?php endif; ?></span>
        <div class="menu-edit-form"
             id="form-<?= (int)$this->i ?>"
             <?php echo (isset($this->pagesDisplay[$this->i]) && $this->pagesDisplay[$this->i]) ? '' : 'hidden' ?>>
            <?php include __DIR__ . "/menu-page-form.phtml"; ?>
        </div>
    </div>


    <div class="menu-item-actions">
        <button type="button" class="menu-action-btn menu-action-btn--edit"
                title="<?php echo $this->escape($this->translate('Modifier')) ?>"
                aria-label="<?php echo $this->escape($this->translate('Modifier') . ' : ' . $this->page->getLabel(Zend_Registry::get('lang'))) ?>"
                aria-expanded="<?php echo (isset($this->pagesDisplay[$this->i]) && $this->pagesDisplay[$this->i]) ? 'true' : 'false' ?>"
                aria-controls="form-<?= (int)$this->i ?>"
                data-action="toggle-edit">
            <span class="glyphicon glyphicon-pencil" aria-hidden="true"></span>
        </button>
        <button type="button" class="menu-action-btn menu-action-btn--delete"
                title="<?php echo $this->escape($this->translate('Supprimer')) ?>"
                aria-label="<?php echo $this->escape($this->translate('Supprimer') . ' : ' . $this->page->getLabel(Zend_Registry::get('lang'))) ?>"
                data-idx="<?= (int)$this->i ?>"
                data-page-resource="<?= $this->escape($this->page->getResource()) ?>"
                data-action="delete-page">
            <span class="glyphicon glyphicon-trash" aria-hidden="true"></span>
        </button>
    </div>

</div>
